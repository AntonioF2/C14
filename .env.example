# Exemplo de variáveis de ambiente
# Copie este arquivo para .env e preencha os valores

# Docker
DOCKER_USERNAME=seu_usuario_docker
DOCKER_PASSWORD=seu_token_docker

# Email (para notificações)
EMAIL_FROM=seu_email@exemplo.com
EMAIL_RECIPIENT=destinatario@exemplo.com

# Railway (deploy)
RAILWAY_TOKEN=seu_token_railway

# GitHub
GITHUB_TOKEN=seu_token_github

# AWS (opcional, para deploy em ECR)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=sua_chave
AWS_SECRET_ACCESS_KEY=seu_secret
